{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/itsraghul/lockwarden/blob/main/packages/cli/src/data/incidents/_schema.json",
  "title": "lockwarden incident IOC bundle",
  "type": "object",
  "required": ["id", "name", "date", "summary", "packages"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Stable incident id used by `lockwarden check --incident <id>`, e.g. \"node-ipc-may26\""
    },
    "name": { "type": "string" },
    "date": { "type": "string", "format": "date" },
    "summary": { "type": "string" },
    "references": {
      "type": "array",
      "items": { "type": "string", "format": "uri" }
    },
    "packages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "versions": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Exact compromised versions"
          },
          "ranges": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Semver ranges, for incidents published across whole lines"
          }
        }
      }
    },
    "fileIocs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      },
      "description": "On-disk indicators, matched by `lockwarden scan`"
    }
  }
}
