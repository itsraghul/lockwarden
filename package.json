{
  "name": "@lockwarden/monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "build": "pnpm --filter lockwarden build",
    "test": "vitest run",
    "test:unit": "vitest run --project cli-unit",
    "test:integration": "vitest run --project cli-integration",
    "typecheck": "pnpm -r --filter '!site' exec tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "corpus:fetch": "pnpm --filter @lockwarden/corpus fetch",
    "corpus:build": "pnpm --filter @lockwarden/corpus build-malicious",
    "corpus:run": "pnpm --filter @lockwarden/corpus run-calibration",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.10",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "tsup": "^8.3.5",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  }
}
